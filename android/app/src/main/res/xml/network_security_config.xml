<?xml version="1.0" encoding="utf-8"?>
<!--
    Allows cleartext (HTTP) traffic for all domains.
    Required for RAWG clip URLs that may use HTTP, and ensures ExoPlayer
    (used by video_player) can stream from any HTTP/HTTPS source.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
