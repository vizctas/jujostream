<?xml version="1.0" encoding="utf-8"?>
<!--
  Android Data Extraction Rules (API 31+).
  Referenced by android:dataExtractionRules in AndroidManifest.xml.

  Pairing state (saved_computers in FlutterSharedPreferences) stores the
  server pair status and server certificate exchanged during the 5-phase
  challenge-response protocol. This data is device-bound:

    - Cloud Backup restore → stale PAIRED state, server rejects HTTPS calls
    - Device-to-device transfer → two devices share same uniqueId=0123456789ABCDEF,
      server only honours the last registration; older device loses pair status

  Excluding from both cloud-backup and device-transfer forces HTTPS re-verification
  on first launch, ensuring the displayed pair state always matches the server.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="FlutterSharedPreferences.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="FlutterSharedPreferences.xml" />
    </device-transfer>
</data-extraction-rules>
